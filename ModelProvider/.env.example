# ModelProvider —— .env 示例
#
# 复制为 .env（本文件放在仓库根或运行目录），填入真实 key。
# .env 已被根 .gitignore 排除，不会被提交。

# ---- 闭源大模型 API key ----
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---- 可选：覆盖 base_url（自建网关 / 代理 / 兼容端点）----
# OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ---- cli_agent provider：claude_code / codex ----
# 不需要 API key —— 直接复用终端里已登录的 Claude Code / Codex CLI 会话/订阅，
# 通过 subprocess 调用本地可执行文件。仅当对应 CLI 不在 PATH 时才需要下面两个变量。
# CLAUDE_CODE_BIN=claude
# CODEX_CLI_BIN=codex
# 命令行模板与所装 CLI 版本的参数不一致时，可整体覆盖（{prompt} 会被替换为实际 prompt）：
# MODELTOOLBOX_CLAUDE_CODE_CMD=claude -p {prompt}
# MODELTOOLBOX_CODEX_CMD=codex exec {prompt}

# ---- 可选：覆盖各 provider 默认模型 ----
# OPENAI_MODEL=gpt-4o-mini
# DEEPSEEK_MODEL=deepseek-chat
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# GEMINI_MODEL=gemini-1.5-flash
# OLLAMA_MODEL=llama3.1

# ---- 三个角色 -> provider:model（可覆盖默认）----
# teacher  = 数据蒸馏老师（合成训练样本）
# fallback = 兜底 / 与私有模型对比的旗舰
# runner   = 训练完成前先跑通的本地模型
# MODELTOOLBOX_TEACHER=anthropic:claude-3-5-sonnet-latest
# MODELTOOLBOX_FALLBACK=openai:gpt-4o-mini
# MODELTOOLBOX_RUNNER=ollama:llama3.1
# 也可以指到本地已登录的编码助手 CLI，免 API key：
# MODELTOOLBOX_TEACHER=claude_code
# MODELTOOLBOX_TEACHER=codex
